# 生产环境配置
NODE_ENV=production

# API配置
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=30000

# 媒体文件配置
VITE_MEDIA_BASE_URL=/static/uploads
VITE_MAX_FILE_SIZE=104857600
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,avi,mov,pdf,txt

# 应用配置
VITE_APP_TITLE=Timeline Notebook
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=个人时光轴记录应用

# 功能开关
VITE_ENABLE_CONSOLE_LOG=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PWA=true

# 性能配置
VITE_CHUNK_SIZE_WARNING_LIMIT=1000
VITE_ASSETS_INLINE_LIMIT=4096