# 前端Dockerfile
FROM node:20-alpine as build

WORKDIR /app

# 复制package文件
COPY frontend/package.json ./

# 删除可能存在的package-lock.json并重新安装
RUN npm install

# 复制源代码
COPY frontend/ .

# 构建应用
RUN npm run build

# 生产环境
FROM nginx:alpine

# 复制构建结果
COPY --from=build /app/dist /usr/share/nginx/html

# 复制nginx配置
COPY nginx.conf /etc/nginx/nginx.conf

# 暴露端口
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]